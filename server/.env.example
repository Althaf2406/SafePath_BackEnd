# Server
PORT=3000

# PostgreSQL connection string
DATABASE_URL=postgres://safepath_user:safepath_pass@localhost:5432/safepath_db

# BMKG cache time-to-live in milliseconds (default 5 minutes)
BMKG_CACHE_TTL_MS=300000

# JWT secret — change this to a long random string in production
JWT_SECRET=safepath-change-this-secret-in-production

